# Pixel Realms — client env vars
#
# Set on Vercel → Project Settings → Environment Variables.
# All VITE_* vars are baked into the client bundle (PUBLIC — never put
# secrets here).

# WebSocket URL of the game server.
# Local dev: leave blank → defaults to ws://<current-host>:2567
# Production: wss://YOUR-RENDER-APP.onrender.com
VITE_SERVER_URL=

# Supabase project URL + ANON / PUBLISHABLE key (NOT service_role).
# Required for Google / GitHub / Discord sign-in. If unset, OAuth buttons
# are hidden and username/password is the only option.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
